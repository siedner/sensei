{
  "name": "sensei",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "pnpm --filter @sensei/server dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "extension:build": "pnpm --filter @sensei/extension build",
    "playbook:dev": "pnpm --filter @sensei/playbook dev",
    "playbook:build": "pnpm --filter @sensei/playbook build"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
