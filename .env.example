SENSEI_AGENT_ADAPTER=mock
SENSEI_PORT=3131

# Provider credentials. Put these in .env.local at the repository root.
# One OpenCode key enables both OpenCode Go and OpenCode Zen.
OPENCODEGO_API_KEY=
OPENAI_API_KEY=

# Optional Pi overrides. By default Pi uses its own configured provider/model.
SENSEI_PI_PROVIDER=
SENSEI_PI_MODEL=

# Optional alternate file containing the provider credentials above.
SENSEI_PROVIDER_ENV_FILE=/Users/mac/code/Rabota/.env.local
